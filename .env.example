# WirelessAgent Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# Application Settings
APP_NAME=WirelessAgent Backend
APP_VERSION=1.0.0
DEBUG=false

# Server Settings
HOST=0.0.0.0
PORT=8000
WORKERS=1

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true

# LLM API Settings
# Get your API key from DeepSeek or OpenAI
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.0

# Knowledge Base Settings
# Path to the Intent_Understand.txt file
KNOWLEDGE_BASE_PATH=./with_knowledge_base/Intent_Understand.txt

# Ray Tracing Data Settings
RAY_TRACING_DATA_PATH=./ray_tracing_results.csv

# Network Slice Configuration
EMBB_TOTAL_CAPACITY=90
URLLC_TOTAL_CAPACITY=30
MMTC_TOTAL_CAPACITY=10

# Logging Settings
LOG_LEVEL=INFO
LOG_FORMAT=json
